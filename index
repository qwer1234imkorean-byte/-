<!-- 완벽 동적 작동을 위한 순수 JavaScript -->
<!-- ========================================== -->
<script>
    // 가상 가입 데이터 저장소 (세션 대용 리스트)
    let userDatabase = [
        { email: "test@gmail.com", pw: "1234", name: "홍길동" }
    ];
    let currentUser = null;

    // 1. 페이지 토글/라우팅 제어 함수
    function showPage(pageId) {
        // 모든 페이지 숨김 처리
        const pages = document.querySelectorAll('.page-content');
        pages.forEach(p => p.style.display = 'none');

        // 사이트맵 전용 별도 아이디 예외 처리 커버
        if (pageId === 'sitemap') {
            document.getElementById('sitemap-page').style.display = 'block';
            resetMenuHighlight();
            return;
        }

        // 선택 페이지 노출
        const targetPage = document.getElementById('page-' + pageId);
        if(targetPage) {
            targetPage.style.display = 'block';
        }

        // GNB 활성화 폰트 하이라이트 제어
        resetMenuHighlight();
        const menuMap = {
            'intro': 'menu-intro', 'guide': 'menu-guide',
            'reserve': 'menu-reserve', 'ships': 'menu-ships', 'cs': 'menu-cs'
        };
        if(menuMap[pageId]) {
            document.getElementById(menuMap[pageId]).classList.add('active');
        }
        
        window.scrollTo(0, 0);
    }

    function resetMenuHighlight() {
        const menus = ['menu-intro', 'menu-guide', 'menu-reserve', 'menu-ships', 'menu-cs'];
        menus.forEach(m => document.getElementById(m).classList.remove('active'));
    }

    // 2. 구글 스타일 가상 로그인 시스템 작동 함수
    function handleLogin(event) {
        event.preventDefault();
        const email = document.getElementById('google-email').value;
        const pw = document.getElementById('google-pw').value;

        // DB 배열 조회 매칭 검증
        const user = userDatabase.find(u => u.email === email && u.pw === pw);

        if(user) {
            currentUser = user;
            alert(user.name + "님, 청해진해운 홈페이지에 성공적으로 로그인하셨습니다.");
            
            // 상단 인터페이스 상태 업데이트 변경
            document.getElementById('status-bar').style.display = 'block';
            document.getElementById('welcome-msg').innerText = user.name;
            document.getElementById('top-login-btn').style.display = 'none';
            
            // 폼 리셋 후 홈으로
            document.getElementById('google-email').value = "";
            document.getElementById('google-pw').value = "";
            showPage('home');
        } else {
            alert("로그인 실패: 이메일 또는 비밀번호가 올바르지 않습니다.\n(테스트 계정: test@gmail.com / 패스워드: 1234)");
        }
    }

    // 3. 로그아웃 핸들러 
    function handleLogout() {
        currentUser = null;
        document.getElementById('status-bar').style.display = 'none';
        document.getElementById('top-login-btn').style.display = 'inline';
        alert("로그아웃 되었습니다.");
        showPage('home');
    }

    // 4. 회원가입 가상 처리 함수
    function handleJoin(event) {
        event.preventDefault();
        const email = document.getElementById('join-email').value;
        const pw = document.getElementById('join-pw').value;
        const name = document.getElementById('join-name').value;

        // 중복 가입 체크
        if(userDatabase.some(u => u.email === email)) {
            alert("이미 가입된 이메일 계정 아이디입니다.");
            return;
        }

        userDatabase.push({ email: email, pw: pw, name: name });
        alert("청해진해운 회원가입이 완료되었습니다!\n방금 가입하신 구글 계정 양식 정보로 로그인이 가능합니다.");
        
        // 인풋 비우기 및 로그인 창으로 리다이렉팅
        document.getElementById('join-email').value = "";
        document.getElementById('join-pw').value = "";
        document.getElementById('join-name').value = "";
        showPage('login');
    }

    // 5. 온라인 승선 예약 시스템 전송 기능 완료 함수
    function handleReserve(event) {
        event.preventDefault();
        const route = document.getElementById('route').value;
        const date = document.getElementById('reserveDate').value;
        const count = document.getElementById('adultCount').value;
        const name = document.getElementById('reserName').value;

        alert(
            "★ 예약 처리가 완료되었습니다 ★\n\n" +
            "· 예약자: " + name + " 귀하\n" +
            "· 예약 노선: " + route + "\n" +
            "· 승선 날짜: " + date + "\n" +
            "· 인원: 성인 " + count + "명\n\n" +
            "출항 당일 신분증을 필히 지참하시고 연안여객터미널 발권 창구로 방문 바랍니다."
        );

        document.getElementById('reservationForm').reset();
        showPage('home');
    }

    // 6. 공지사항 모달 가상 팝업창 바인딩 함수
    function showNotice(id) {
        let title = "";
        let content = "";

        if (id === 1) {
            title = "[안내] 선박 운항 스케줄 변경 안내";
            content = "2014년 4월~5월 봄철 서해 기상 조석 간만의 차에 의해 출항 조율 시간이 유동적으로 변경되오니 승객 여러분께서는 안내실로 재확인 당부드립니다.";
        } else if (id === 2) {
            title = "[공지] 기상 악화로 인한 결항 안내";
            content = "현재 서해 먼바다 풍랑주의보 발효 및 강풍으로 유선 안전상 전 선박 운항이 통제 결항 처리되었습니다. 예매 승객 건은 자동 전액 취소 조치됩니다.";
        } else if (id === 3) {
            title = "[이벤트] 봄맞이 제주도 여객 승선권 단체 할인";
            content = "단체 승객 20인 이상 단체 관광 동호회 분들을 위한 운임료 특별 15% 감면 이벤트 계약 제휴를 성황리에 접수 중입니다.";
        } else if (id === 4) {
            title = "[안내] 홈페이지 서버 및 결제 시스템 점검 안내";
            content = "안정적인 카드 결제 연동 처리를 위해 가상 방화벽 모듈 패치 서버 점검이 있을 예정이오니 서비스 결제 장애 시 유선 연락을 부탁드립니다.";
        }

        alert("▶ 제목: " + title + "\n\n▶ 상세 내용:\n" + content);
    }
</script>

