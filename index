<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>(주)청해진해운 - CHONGHAEJIN MARINE CO., LTD.</title>
    <style>
        /* 2014년 감성 시스템 폰트 고정 및 리셋 */
        body {
            font-family: "돋움", Dotum, "굴림", Gulim, sans-serif;
            font-size: 12px;
            color: #333333;
            margin: 0;
            padding: 0;
            background-color: #f9f9f9;
        }
        ul, li {
            list-style: none;
            margin: 0;
            padding: 0;
        }
        a {
            color: #333333;
            text-decoration: none;
            cursor: pointer;
        }
        a:hover {
            text-decoration: underline;
            color: #0055aa;
        }
        button {
            cursor: pointer;
            font-family: "돋움", Dotum;
        }

        /* 메인 프레임 (1000px 고정폭) */
        #wrap {
            width: 1000px;
            margin: 0 auto;
            background-color: #ffffff;
            border-left: 1px solid #e1e1e1;
            border-right: 1px solid #e1e1e1;
        }

        /* 상단 헤더 */
        header {
            width: 1000px;
            height: 120px;
            position: relative;
        }
        .logo {
            position: absolute;
            top: 35px;
            left: 20px;
            font-size: 24px;
            font-weight: bold;
            color: #0b3880;
            letter-spacing: -1px;
        }
        .top-menu {
            position: absolute;
            top: 15px;
            right: 20px;
        }
        .top-menu li {
            display: inline;
            margin-left: 10px;
            font-size: 11px;
            color: #666666;
        }

        /* 주메뉴 (GNB) */
        nav {
            width: 1000px;
            height: 45px;
            background-color: #0b3880;
        }
        .gnb {
            width: 800px;
            margin: 0 auto;
            display: flex;
        }
        .gnb li {
            flex: 1;
            text-align: center;
        }
        .gnb li a {
            display: block;
            height: 45px;
            line-height: 45px;
            color: #ffffff;
            font-size: 14px;
            font-weight: bold;
        }
        .gnb li a:hover, .gnb li.active a {
            background-color: #03255c;
            text-decoration: none;
        }

        /* 로그인 상태 표시창 */
        .login-status-bar {
            background-color: #f0f4f8;
            padding: 8px 20px;
            text-align: right;
            border-bottom: 1px solid #dddddd;
            font-size: 11px;
            display: none; /* 로그인 시에만 노출 */
        }

        /* 컨텐츠 페이지 제어 스타일 */
        .page-content {
            display: none;
            min-height: 450px;
        }
        .page-content.active {
            display: block;
        }

        /* 1. 홈 화면 */
        .main-visual {
            width: 1000px;
            height: 350px;
            background-color: #d1e4f5;
            display: flex;
            justify-content: center;
            align-items: center;
            border-bottom: 3px solid #0b3880;
        }
        .visual-text {
            text-align: center;
            color: #1a426e;
        }
        .visual-text h2 {
            font-size: 28px;
            margin-bottom: 10px;
        }
        .container {
            padding: 30px 20px;
            display: flex;
            justify-content: space-between;
        }
        .content-box {
            width: 300px;
            height: 200px;
            border: 1px solid #dddddd;
            background-color: #ffffff;
        }
        .box-title {
            padding: 10px;
            background-color: #f5f5f5;
            border-bottom: 1px solid #dddddd;
            font-weight: bold;
            color: #0b3880;
        }
        .box-list {
            padding: 15px;
        }
        .box-list li {
            padding: 5px 0;
            border-bottom: 1px dashed #eeeeee;
            padding-left: 5px;
        }
        .box-list li span {
            float: right;
            color: #999999;
            font-size: 11px;
        }

        /* 공통 서브페이지 규격 */
        .sub-container {
            padding: 40px 30px;
        }
        .sub-title {
            font-size: 20px;
            font-weight: bold;
            color: #0b3880;
            border-bottom: 2px solid #0b3880;
            padding-bottom: 10px;
            margin-bottom: 20px;
        }

        /* 2. 회사소개 / 운항안내 / 선박소개 템플릿용 스타일 */
        .info-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }
        .info-table th {
            background-color: #f5f5f5;
            border: 1px solid #dddddd;
            padding: 12px;
            width: 150px;
            text-align: left;
        }
        .info-table td {
            border: 1px solid #dddddd;
            padding: 12px;
            line-height: 20px;
        }

        /* 3. 예약 예매 양식 */
        .reserve-form {
            background-color: #f8f9fa;
            border: 1px solid #dddddd;
            padding: 20px;
        }
        .form-table {
            width: 100%;
            border-collapse: collapse;
        }
        .form-table th {
            width: 150px;
            text-align: left;
            padding: 12px;
            border-bottom: 1px solid #e5e5e5;
            background-color: #f0f4f8;
        }
        .form-table td {
            padding: 12px;
            border-bottom: 1px solid #e5e5e5;
        }
        select, input[type="date"], input[type="number"], input[type="text"], input[type="password"], input[type="email"] {
            padding: 6px;
            border: 1px solid #cccccc;
            font-size: 12px;
        }
        .btn-submit {
            display: block;
            width: 150px;
            height: 40px;
            background-color: #0b3880;
            color: #ffffff;
            border: none;
            font-weight: bold;
            font-size: 14px;
            margin: 20px auto 0 auto;
        }

        /* 4. 고객센터 게시판 */
        .board-table {
            width: 100%;
            border-collapse: collapse;
        }
        .board-table th {
            background-color: #f5f5f5;
            border-top: 1px solid #0b3880;
            border-bottom: 1px solid #dddddd;
            padding: 10px;
        }
        .board-table td {
            border-bottom: 1px solid #eeeeee;
            padding: 10px;
            text-align: center;
        }
        .board-table td.left {
            text-align: left;
            padding-left: 15px;
        }

        /* 5. 회원가입 양식 */
        .join-box {
            max-width: 500px;
            margin: 0 auto;
            border: 1px solid #dddddd;
            padding: 30px;
            background-color: #ffffff;
        }

        /* ==================================================================
           ★ 2014년도 GOOGLE 로그인 스타일 플랫 디자인 (Flat UI 초기 감성)
        ================================================================== */
        .google-login-container {
            padding: 60px 0;
            background-color: #f1f1f1;
            display: flex;
            justify-content: center;
        }
        .google-card {
            width: 352px;
            background-color: #ffffff;
            padding: 40px;
            border-radius: 2px;
            box-shadow: 0px 2px 2px rgba(0, 0, 0, 0.3);
            text-align: center;
        }
        .google-avatar {
            width: 96px;
            height: 96px;
            background-color: #dfdfdf;
            border-radius: 50%;
            margin: 0 auto 20px auto;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 45px;
            color: #ffffff;
        }
        .google-card input[type="text"], .google-card input[type="password"] {
            width: 100%;
            height: 44px;
            font-size: 16px;
            margin-bottom: 10px;
            box-sizing: border-box;
            padding-left: 10px;
            border: 1px solid #d9d9d9;
            border-top: 1px solid #c0c0c0;
        }
        .google-card input[type="text"]:focus, .google-card input[type="password"]:focus {
            border: 1px solid #4d90fe;
            outline: none;
        }
        .btn-google-login {
            width: 100%;
            height: 36px;
            background-color: #4d90fe;
            border: 1px solid #3079ed;
            color: #ffffff;
            font-size: 14px;
            font-weight: bold;
            border-radius: 2px;
            text-shadow: 0 1px rgba(0,0,0,0.1);
        }
        .btn-google-login:hover {
            background-color: #357ae8;
            border: 1px solid #2f5bb7;
        }
        .google-footer-links {
            margin-top: 20px;
            font-size: 13px;
        }
        .google-footer-links a {
            color: #4285f4;
        }

        /* 하단 푸터 */
        footer {
            width: 1000px;
            background-color: #444444;
            color: #aaaaaa;
            padding: 20px 0;
            border-top: 1px solid #333333;
            margin-top: 30px;
        }
        .footer-menu {
            padding-left: 20px;
            margin-bottom: 15px;
        }
        .footer-menu li {
            display: inline;
            margin-right: 15px;
        }
        .footer-menu li a {
            color: #dddddd;
            font-weight: bold;
        }
        .company-info {
            padding-left: 20px;
            line-height: 18px;
            font-size: 11px;
        }
        .copyright {
            margin-top: 10px;
            color: #888888;
        }
    </style>
</head>
